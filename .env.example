# OpenAI
OPENAI_API_KEY=sk-...

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token   # any random string you choose

# App
FLASK_SECRET_KEY=change_this_to_a_random_string
CHROMA_DB_PATH=./chroma_db
DOCUMENTS_PATH=./documents
CONVERSATION_DB_PATH=./data/conversations.db

# PostgreSQL
POSTGRES_DSN=postgresql://dopshy:changeme@postgres:5432/dopshy
POSTGRES_PASSWORD=changeme
POSTGRES_MAX_CONN=10

# Google Sheets (flat one-row-per-booking "Bookings" worksheet)
GOOGLE_CREDENTIALS_PATH=./secrets/google_credentials.json
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_from_url
GOOGLE_WORKSHEET_NAME=Bookings

# Manager API (Google Apps Script → backend)
MANAGER_API_KEY=change_this_to_a_long_random_string
MANAGER_RATE_LIMIT=60

# Directus admin panel (shares the bot's PostgreSQL).
# Generate KEY and SECRET with:  openssl rand -hex 32
DIRECTUS_KEY=
DIRECTUS_SECRET=
DIRECTUS_ADMIN_EMAIL=admin@dopsy.kz
DIRECTUS_ADMIN_PASSWORD=change_this_to_a_strong_password
DIRECTUS_PUBLIC_URL=http://localhost:8055

# Booking (Bot 1 — Dopshy field rental)
BOOKING_OPEN_TIME=09:00
BOOKING_CLOSE_TIME=23:00
BOOKING_SLOT_DURATION=60
BOOKING_FIELDS=[{"id":1,"format":"5x5"},{"id":2,"format":"6x6"}]
BOOKING_TIMEZONE=Asia/Almaty
BOOKING_SESSION_TTL=1800
KASPI_PAYMENT_URL=https://pay.kaspi.kz/pay/z7xcvrgq

# Optional
PORT=5000

# Nginx + Let's Encrypt (public webhook URL)
# Dev: SERVER_NAME=bot.dopsy.kz  |  Prod: SERVER_NAME=bot.dopsy.kz
SERVER_NAME=bot.dopsy.kz
CERTBOT_EMAIL=admin@dopsy.kz
